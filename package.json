{
  "name": "onivoro",
  "version": "0.0.1",
  "license": "MIT",
  "scripts": {
    "nx": "nx",
    "random": "echo 'pass a numeric arg to change the default length of 16' & bun tools/scripts/rando.ts",
    "db:up:local": "cd docker/dev && docker compose up -d --remove-orphans",
    "db:down:local": "cd docker/dev && docker compose down",
    "fmt": "nx format --fix",
    "setup:mcp": "node scripts/setup-mcp-config.js",
    "setup:mcp:dry-run": "node scripts/setup-mcp-config.js --dry-run",
    "test": "npm run test:unit",
    "test:unit": "nx run-many -t test --passWithNoTests",
    "_release_comment": "Use release:patch/minor/major to version, build, commit, tag and publish packages",
    "release:patch": "nx release version patch && npm run release:complete",
    "release:minor": "nx release version minor && npm run release:complete",
    "release:major": "nx release version major && npm run release:complete",
    "release:version": "nx release version",
    "release:build": "nx run-many -t build --projects='lib-server-*,lib-isomorphic-*,lib-browser-*' --skip-nx-cache",
    "release:commit": "git add . && git commit -m \"chore(release): v$(node -p \"require('./libs/server/common/package.json').version\")\" || echo 'No changes to commit'",
    "release:tag": "git tag \"v$(node -p \"require('./libs/server/common/package.json').version\")\" || echo 'Tag already exists'",
    "release:publish": "nx release publish",
    "release:check-version": "test $(git diff --name-only | grep -c package.json) -gt 0 || (echo 'ERROR: No version changes detected. Run npm run release:patch/minor/major first!' && exit 1)",
    "release:complete": "npm run release:check-version && npm run release:build && npm run release:commit && npm run release:tag && npm run release:publish",
    "release:dry-run": "nx release version patch --dry-run"
  },
  "private": true,
